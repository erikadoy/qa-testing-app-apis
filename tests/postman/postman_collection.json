    {
      "name": "Post data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "pm.environment.set(\"project_name\", response.project_name);",
              "pm.test(\"Project created successfully\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "console.log(\"Captured project_name:\", response.project_name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a unique project name for testing\r",
              "const timestamp = new Date().getTime();\r",
              "const projectName = `com.azure.TestProject${timestamp}`;\r",
              "\r",
              "// Save in environment variables\r",
              "pm.environment.set(\"project_name\", projectName);\r",
              "pm.environment.set(\"team_name\", \"Platform Engineering\"); // valid team name\r",
              "pm.environment.set(\"templates\", JSON.stringify([\"frontend-react\",\"api-gateway\"]));\r",
              "\r",
              "// Update request body dynamically\r",
              "const requestBody = {\r",
              "    project_name: projectName,\r",
              "    team_name: pm.environment.get(\"team_name\"),\r",
              "    templates: JSON.parse(pm.environment.get(\"templates\")),\r",
              "    status: \"active\"\r",
              "};\r",
              "\r",
              "pm.request.body.raw = JSON.stringify(requestBody);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project_name\": \"{{project_name}}\",\n  \"team_name\": \"Platform Engineering\",\n  \"templates\": [\"frontend-react\", \"api-gateway\"]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/projects",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "8000",
          "path": [
            "api",
            "v1",
            "projects"
          ]
        },
        "description": "This is a POST request, submitting data to an API via the request body. This request submits JSON data, and the data is reflected in the response.\n\nA successful POST request typically returns a `200 OK` or `201 Created` response code."
      },
